---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import RouteStage from "../components/RouteStage.astro";
import TechIcon from "../components/TechIcon.astro";
import { routeStages, techStack } from "../data/ruta.js";
---

<BaseLayout title="Ruta de aprendizaje | Chilete DevPath">
  <PageHero
    eyebrow="Ruta de aprendizaje"
    title="Empieza por fundamentos y avanza con practica real"
    description="La ruta organiza que aprender, que practicar y que revisar antes de pasar al siguiente nivel."
    variant="ruta"
    visualTitle="Mapa de avance"
    visualText="Secuencia visual para avanzar desde fundamentos hasta proyectos."
  />

  <section class="seccion">
    <div class="contenedor">
      <div class="ruta-etapas">
        {routeStages.map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>El contenido practico vive en el repositorio de aprendizaje y seguira creciendo con ejercicios aprobados, desarrollados y revisados.</p>
        <a class="boton boton-principal" href="https://github.com/chiletedevpath/aprendizaje" target="_blank" rel="noopener">
          Abrir aprendizaje
        </a>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Tecnologias en practica"
        title="Herramientas que aparecen en la ruta"
        description="La ruta combina bases web, programacion, datos y backend. Cada tecnologia entra cuando aporta al aprendizaje, no por adorno."
      />
      <div class="tech-grid" aria-label="Tecnologias usadas en Chilete DevPath">
        {techStack.map((tech) => (
          <a
            class={`tech-badge tech-${tech.tone}`}
            href={tech.href}
            target="_blank"
            rel="noopener"
            aria-label={`Ver aprendizaje relacionado con ${tech.name}`}
          >
            <span class="tech-icono"><TechIcon name={tech.name} /></span>
            <div>
              <strong>{tech.name}</strong>
              <p>{tech.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
