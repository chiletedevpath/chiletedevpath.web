---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import RouteStage from "../components/RouteStage.astro";
import TechIcon from "../components/TechIcon.astro";
import { routeStages, techStack } from "../data/ruta.js";
---

<BaseLayout title="Ruta de aprendizaje | Chilete DevPath">
  <PageHero
    eyebrow="Ruta de aprendizaje"
    title="Empieza por fundamentos y avanza con práctica real"
    description="Aquí ordeno el camino como me hubiera gustado encontrarlo: primero entender la base, luego practicar y después construir proyectos con más criterio."
    variant="ruta"
    heroImage="/assets/img/heros/ruta-chiletedevpath.png"
    showVisual={false}
    visualTitle="Camino de avance"
    visualText="Una ruta progresiva desde la base hasta proyectos con evidencia."
    visualLabel="Mapa de avance"
    visualHeadline="De fundamentos a proyectos"
    visualItems={[
      { title: "Fundamentos", text: "Comprender antes de programar." },
      { title: "Construcción", text: "Organizar soluciones con criterio." },
      { title: "Web y datos", text: "Conectar práctica, consultas y documentación." },
      { title: "Proyectos", text: "Convertir avance en evidencia revisable." },
      { title: "Mejora continua", text: "Revisar, corregir y seguir avanzando." },
    ]}
  />

  <section class="seccion seccion-editorial">
    <div class="contenedor editorial-bloque">
      <div class="editorial-frase">
        <p class="etiqueta">Reflexión de aprendizaje</p>
        <blockquote>Programar no es correr detrás del código; es aprender a pensar antes de escribirlo.</blockquote>
        <p>
          Por eso la ruta empieza con fundamentos y avanza con práctica. La meta no es llenar carpetas,
          sino construir criterio para resolver mejor.
        </p>
      </div>
      <figure class="editorial-imagen">
        <img src="/assets/img/editorial/ChatGPT Image 26 jun 2026, 03_07_26 a.m..png" alt="Adrian Pisco trabajando en Chilete DevPath" loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="ruta-etapas">
        {routeStages.map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>El contenido práctico vive en el repositorio de aprendizaje. Lo seguiré ampliando con ejercicios útiles, glosarios puntuales y laboratorios cuando realmente ayuden a aprender.</p>
        <a class="boton boton-principal" href="https://github.com/chiletedevpath/aprendizaje" target="_blank" rel="noopener noreferrer">
          Abrir aprendizaje
        </a>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Tecnologías en práctica"
        title="Herramientas que aparecen en la ruta"
        description="Estas tecnologías aparecen porque ayudan a resolver algo dentro de la ruta. No están para decorar una lista, sino para practicar con propósito."
      />
      <div class="tech-grid" aria-label="Tecnologias usadas en Chilete DevPath">
        {techStack.map((tech) => (
          <a
            class={`tech-badge tech-${tech.tone}`}
            href={tech.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Ver aprendizaje relacionado con ${tech.name}`}
          >
            <span class="tech-icono"><TechIcon name={tech.name} /></span>
            <div>
              <strong>{tech.name}</strong>
              <p>{tech.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
