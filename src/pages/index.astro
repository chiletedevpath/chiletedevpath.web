---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import RouteStage from "../components/RouteStage.astro";
import { routeStages } from "../data/ruta.js";
import { projectAreas } from "../data/proyectos.js";
import { metrics, site, valueProps } from "../data/site.js";

const learningActions = [
  {
    step: "01",
    title: "Empieza por fundamentos",
    text: "Comprende logica, variables, decisiones, ciclos y forma de pensar antes de correr por tecnologia.",
    href: "/ruta/",
    action: "Ver ruta",
  },
  {
    step: "02",
    title: "Practica con ejercicios",
    text: "Usa ejercicios desarrollados y retos propuestos para convertir teoría en criterio técnico.",
    href: "/recursos/",
    action: "Abrir recursos",
  },
  {
    step: "03",
    title: "Mira evidencia real",
    text: "Revisa proyectos académicos en proceso con estado claro, contexto y publicación responsable.",
    href: "/proyectos/",
    action: "Ver proyectos",
  },
];
---

<BaseLayout>
  <Hero />

  <section class="seccion seccion-clara inicio-aprendizaje">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Empieza aqui"
        title="Una ruta para aprender con orden, practica y evidencia"
        description="Chilete DevPath no es solo una vitrina personal. Es un camino público para estudiar, practicar, revisar proyectos y publicar con criterio."
      />

      <div class="acciones-aprendizaje">
        {learningActions.map((item) => (
          <article class="accion-aprendizaje">
            <span>{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href={item.href}>{item.action}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Por que Chilete DevPath"
        title="Aprender no es acumular carpetas: es construir criterio"
        description="La marca ordena el proceso para que cualquier estudiante entienda que practicar, que revisar y como convertir avances en evidencia publica responsable."
      />
      <div class="tarjetas tarjetas-4 valor-grid">
        {valueProps.map((item) => (
          <article class="tarjeta valor-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor metricas-panel">
      <div>
        <p class="etiqueta">Ecosistema en crecimiento</p>
        <h2>Indicadores reales del avance publicado</h2>
        <p>
          Estas métricas resumen el contenido disponible y se actualizan cuando la ruta,
          los proyectos o las políticas cambian de forma verificable.
        </p>
      </div>
      <div class="metricas-grid">
        {metrics.map((metric) => (
          <article class="metrica-card">
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
            <small>{metric.detail}</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ruta de aprendizaje"
        title="De fundamentos a construccion tecnica"
        description="La ruta muestra que aprender primero, que practicar despues y como conectar el avance con proyectos reales."
      />
      <div class="ruta-etapas ruta-etapas-compacta">
        {routeStages.slice(0, 4).map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>Explora la ruta completa, ejercicios desarrollados y practicas pensadas para aprender construyendo.</p>
        <a class="boton boton-principal" href="/ruta/">Ver ruta completa</a>
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ecosistema DevPath"
        title="Cada espacio tiene una funcion clara"
        description="Aprendizaje para practicar, academia para evidenciar, portafolio para seleccionar y criterios para publicar sin improvisar."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreas.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="seccion contacto-formal" id="contacto">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Contacto y feedback</p>
        <h2>Envía una duda, sugerencia o propuesta</h2>
        <p>
          El panel prepara tu mensaje en el navegador y abre WhatsApp o tu cliente de correo.
          No guarda datos en la web ni los publica.
        </p>
        <a class="boton boton-secundario" href={site.mapsHref} target="_blank" rel="noopener">
          Ver origen en Chilete
        </a>
      </div>
      <div class="formulario-contacto panel-contacto" data-contact-panel data-context="Consulta desde la pagina de inicio">
        <label>
          Nombre
          <input type="text" name="nombre" autocomplete="name" required />
        </label>
        <label>
          Correo
          <input type="email" name="correo" autocomplete="email" required />
        </label>
        <label>
          Mensaje
          <textarea name="mensaje" rows="5" required></textarea>
        </label>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-whatsapp>Enviar por WhatsApp</button>
          <button class="boton boton-secundario" type="button" data-send-email>Enviar por correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
