---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import RouteStage from "../components/RouteStage.astro";
import { routeStages } from "../data/ruta.js";
import { projectAreas } from "../data/proyectos.js";
import { metrics, site, valueProps } from "../data/site.js";

const learningActions = [
  {
    step: "01",
    title: "Empieza por fundamentos",
    text: "Antes de correr por frameworks, quiero que la base se entienda: lógica, decisiones, ciclos y forma de pensar.",
    href: "/ruta/",
    action: "Ver ruta",
  },
  {
    step: "02",
    title: "Practica con ejercicios",
    text: "Los ejercicios sirven para equivocarse, comparar, corregir y aprender con más criterio.",
    href: "/recursos/",
    action: "Abrir recursos",
  },
  {
    step: "03",
    title: "Mira evidencia real",
    text: "Los proyectos muestran avance real, con contexto y sin vender como final algo que aún está creciendo.",
    href: "/proyectos/",
    action: "Ver proyectos",
  },
];

const audience = [
  "Estudiantes que empiezan programación y necesitan una ruta clara.",
  "Personas que quieren practicar con ejercicios antes de saltar a proyectos.",
  "Desarrolladores en formación que quieren documentar y publicar mejor.",
  "Comunidad que busca ejemplos reales sin perder criterio técnico.",
];
---

<BaseLayout>
  <Hero />

  <section class="seccion seccion-clara inicio-aprendizaje">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Empieza aquí"
        title="Una ruta para aprender con orden, práctica y evidencia"
        description="Chilete DevPath nace para compartir mi camino de aprendizaje y convertirlo en una guía útil para otros estudiantes."
      />

      <div class="acciones-aprendizaje">
        {learningActions.map((item) => (
          <article class="accion-aprendizaje">
            <span>{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href={item.href}>{item.action}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Por qué Chilete DevPath"
        title="Aprender no es acumular carpetas: es construir criterio"
        description="No quiero que Chilete DevPath sea solo un GitHub ordenado. Quiero que sea una guía para saber qué aprender, cómo practicar y cuándo algo está listo para compartirse."
      />
      <div class="tarjetas tarjetas-4 valor-grid">
        {valueProps.map((item) => (
          <article class="tarjeta valor-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Para quién es"
        title="Una web para aprender con guía, práctica y contexto"
        description="Si estás empezando o quieres reforzar tu base, esta web debe ayudarte a entrar sin perderte entre carpetas, repositorios o nombres técnicos."
      />
      <div class="tarjetas tarjetas-4">
        {audience.map((item) => (
          <article class="tarjeta audiencia-card">
            <span class="estado">DevPath</span>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor metricas-panel">
      <div>
        <p class="etiqueta">Ecosistema en crecimiento</p>
        <h2>Así va creciendo Chilete DevPath</h2>
        <p>
          Estos números no intentan aparentar más de lo que hay. Los actualizo cuando agrego contenido real:
          temas revisados, proyectos con contexto o criterios que sí ayudan a publicar mejor.
        </p>
      </div>
      <div class="metricas-grid">
        {metrics.map((metric) => (
          <article class="metrica-card">
            <strong data-count={metric.value}>{metric.value}</strong>
            <span>{metric.label}</span>
            <small>{metric.detail}</small>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ruta de aprendizaje"
        title="De fundamentos a construcción técnica"
        description="La ruta indica por dónde empezar, qué practicar después y cómo conectar el avance con proyectos reales."
      />
      <div class="ruta-etapas ruta-etapas-compacta">
        {routeStages.slice(0, 4).map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>Explora la ruta completa, ejercicios desarrollados y prácticas pensadas para aprender construyendo.</p>
        <a class="boton boton-principal" href="/ruta/">Ver ruta completa</a>
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ecosistema DevPath"
        title="Cada espacio tiene una función clara"
        description="Aprendizaje es para practicar, academia para evidenciar, portafolio para seleccionar y criterios para publicar sin improvisar."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreas.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="seccion contacto-formal" id="contacto">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Contacto y feedback</p>
        <h2>Escríbeme si algo de la ruta puede mejorar</h2>
        <p>
          Este formulario prepara un correo. Lo uso para recibir dudas, ideas y mejoras sin publicar datos de nadie
          en la web. Si quieres contacto directo, el botón de WhatsApp está disponible aparte.
        </p>
        <a class="boton boton-secundario boton-mapa" href={site.mapsHref} target="_blank" rel="noopener">
          Ver Chilete en el mapa
        </a>
      </div>
      <div class="formulario-contacto panel-contacto formulario-correo" data-contact-panel data-context="Consulta desde la página de inicio">
        <div class="formulario-cabecera">
          <span>Correo revisable</span>
          <strong>Tu mensaje se prepara antes de enviarse</strong>
          <p>La web no guarda tu información. Al hacer clic se abre tu cliente de correo para que revises el contenido y recién lo envíes.</p>
        </div>
        <div class="formulario-opciones">
          <label>
            Nombre
            <input type="text" name="nombre" autocomplete="name" placeholder="Tu nombre" required />
          </label>
          <label>
            Correo
            <input type="email" name="correo" autocomplete="email" placeholder="tu.correo@ejemplo.com" required />
          </label>
        </div>
        <label>
          Tipo de mensaje
          <select name="tipo" required>
            <option value="Duda sobre la ruta">Duda sobre la ruta</option>
            <option value="Sugerencia de recurso">Sugerencia de recurso</option>
            <option value="Propuesta de colaboración">Propuesta de colaboración</option>
            <option value="Reporte de mejora">Reporte de mejora</option>
          </select>
        </label>
        <label>
          Mensaje
          <textarea name="mensaje" rows="5" maxlength="700" data-countable placeholder="Cuéntame el contexto con claridad. Mientras más concreto, mejor puedo revisar tu mensaje." required></textarea>
        </label>
        <small class="contador-caracteres" data-counter>0/700</small>
        <p class="nota-privacidad">Tu mensaje no aparece públicamente ni se guarda en una base de datos. Solo se usa para preparar un correo dirigido a Chilete DevPath.</p>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-email>Preparar correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
