---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import RouteStage from "../components/RouteStage.astro";
import { routeStages } from "../data/ruta.js";
import { projectAreas } from "../data/proyectos.js";

const learningActions = [
  {
    step: "01",
    title: "Empieza por fundamentos",
    text: "Comprende lógica, variables, decisiones, ciclos y forma de pensar antes de correr por tecnología.",
    href: "/ruta/",
    action: "Ver ruta",
  },
  {
    step: "02",
    title: "Practica con ejercicios",
    text: "Usa ejercicios desarrollados y retos propuestos para convertir teoría en criterio técnico.",
    href: "/recursos/",
    action: "Abrir recursos",
  },
  {
    step: "03",
    title: "Mira evidencia real",
    text: "Revisa proyectos académicos en proceso con estado claro, contexto y publicación responsable.",
    href: "/proyectos/",
    action: "Ver proyectos",
  },
];
---

<BaseLayout>
  <Hero />

  <section class="seccion seccion-clara inicio-aprendizaje">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Empieza aquí"
        title="Una ruta para aprender con orden, práctica y evidencia"
        description="Chilete DevPath no es solo una vitrina personal. Es un camino público para estudiar, practicar, revisar proyectos y publicar con criterio."
      />

      <div class="acciones-aprendizaje">
        {learningActions.map((item) => (
          <article class="accion-aprendizaje">
            <span>{item.step}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
            <a href={item.href}>{item.action}</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ruta de aprendizaje"
        title="De fundamentos a construcción técnica"
        description="La ruta muestra qué aprender primero, qué practicar después y cómo conectar el avance con proyectos reales."
      />
      <div class="ruta-etapas ruta-etapas-compacta">
        {routeStages.slice(0, 4).map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>Explora la ruta completa, ejercicios desarrollados y prácticas pensadas para aprender construyendo.</p>
        <a class="boton boton-principal" href="/ruta/">Ver ruta completa</a>
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ecosistema DevPath"
        title="Cada espacio tiene una funcion clara"
        description="Aprendizaje para practicar, academia para evidenciar, portafolio para seleccionar y criterios para publicar sin improvisar."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreas.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
