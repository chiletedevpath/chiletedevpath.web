---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { resources } from "../data/recursos.js";
import { site } from "../data/site.js";
---

<BaseLayout title="Recursos | Chilete DevPath">
  <PageHero
    eyebrow="Recursos"
    title="Practica, revisa y avanza con material organizado"
    description="Esta seccion funciona como biblioteca de aprendizaje: ejercicios, retos, glosarios y criterios para consultar sin perderte entre carpetas."
    variant="recursos"
    visualTitle="Biblioteca DevPath"
    visualText="Material para resolver, estudiar y publicar con criterio."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Como usar esta seccion"
        title="Elige el recurso segun tu momento de aprendizaje"
        description="Si aun estas practicando, empieza por retos. Si ya intentaste resolver, revisa ejercicios desarrollados. Si tienes dudas de lenguaje tecnico, consulta el glosario."
      />
      <div class="tarjetas tarjetas-4">
        {resources.map((resource) => (
          <article class="tarjeta recurso-card">
            <span class="estado">{resource.status}</span>
            <small>{resource.type}</small>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <a href={resource.href} target={resource.href.startsWith("http") ? "_blank" : undefined} rel={resource.href.startsWith("http") ? "noopener" : undefined}>
              Ver recurso
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Sugerencias de recursos</p>
        <h2>Ayuda a priorizar que material falta</h2>
        <p>
          Si un tema necesita ejercicios, glosario o laboratorio, envia la sugerencia. Primero se revisa
          que aporte a la ruta y que pueda publicarse sin riesgo legal o academico.
        </p>
      </div>
      <div class="formulario-contacto panel-contacto" data-contact-panel data-context="Sugerencia de recurso">
        <label>
          Tema sugerido
          <input type="text" name="tema" required />
        </label>
        <label>
          Tipo de recurso
          <select name="tipo" required>
            <option value="Ejercicio">Ejercicio</option>
            <option value="Reto">Reto</option>
            <option value="Glosario">Glosario</option>
            <option value="Guia">Guia</option>
          </select>
        </label>
        <label>
          Motivo
          <textarea name="motivo" rows="5" required></textarea>
        </label>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-whatsapp>Enviar por WhatsApp</button>
          <button class="boton boton-secundario" type="button" data-send-email>Enviar por correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
