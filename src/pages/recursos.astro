---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { resources } from "../data/recursos.js";

const resourceFilters = [
  { label: "Todos", value: "todos" },
  { label: "Ejercicios", value: "ejercicios" },
  { label: "Retos", value: "retos" },
  { label: "Glosario", value: "glosario" },
  { label: "Guías", value: "guias" },
  { label: "Java", value: "java" },
  { label: "Web", value: "web" },
  { label: "SQL", value: "sql" },
];
---

<BaseLayout title="Recursos | Chilete DevPath">
  <PageHero
    eyebrow="Recursos"
    title="Practica, revisa y avanza con material organizado"
    description="Esta sección debe ayudarte a encontrar qué resolver, qué consultar y qué revisar sin tener que adivinar en qué carpeta está cada cosa."
    variant="recursos"
    heroImage="/assets/img/heros/recursos-chiletedevpath.webp"
    showVisual={false}
    visualTitle="Biblioteca práctica"
    visualText="Ejercicios, retos, guías y glosarios conectados a la ruta."
    visualItems={[
      { title: "Resolver", text: "Practicar antes de mirar una solución." },
      { title: "Estudiar", text: "Revisar ejercicios desarrollados con calma." },
      { title: "Consultar", text: "Usar glosarios y guías cuando falte contexto." },
    ]}
  />

  <section class="seccion seccion-editorial">
    <div class="contenedor editorial-bloque">
      <div class="editorial-frase">
        <p class="etiqueta">Material con intención</p>
        <blockquote>Un recurso sirve cuando te ayuda a intentar, equivocarte, revisar y volver a intentarlo con más claridad.</blockquote>
        <p>
          Los ejercicios, glosarios y guías deben acompañar el proceso de aprendizaje. No se trata de acumular enlaces,
          sino de tener apoyo concreto para avanzar con orden.
        </p>
      </div>
      <figure class="editorial-imagen">
        <img src="/assets/img/editorial/ChatGPT Image 26 jun 2026, 03_07_19 a.m..webp" alt="Adrian Pisco explicando la ruta de aprendizaje" loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Cómo usar esta sección"
        title="Elige el recurso según tu momento de aprendizaje"
        description="Si quieres practicar, entra a retos. Si ya intentaste resolver algo, revisa ejercicios desarrollados. Si un término no queda claro, usa el glosario como apoyo."
      />
      <div class="filtros-recursos" aria-label="Filtros de recursos">
        {resourceFilters.map((filter, index) => (
          <button
            class={index === 0 ? "filtro-recurso filtro-activo" : "filtro-recurso"}
            type="button"
            data-resource-filter={filter.value}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {filter.label}
          </button>
        ))}
      </div>
      <div class="tarjetas tarjetas-4">
        {resources.map((resource) => (
          <article class="tarjeta recurso-card" data-resource-category={resource.category} data-resource-tags={resource.tags?.join(" ")}>
            <span class="estado">{resource.status}</span>
            <small>{resource.type}</small>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <dl class="recurso-meta">
              <div>
                <dt>Nivel</dt>
                <dd>{resource.level}</dd>
              </div>
              <div>
                <dt>Tema</dt>
                <dd>{resource.topic}</dd>
              </div>
              <div>
                <dt>Tiempo</dt>
                <dd>{resource.time}</dd>
              </div>
            </dl>
            <a href={resource.href} target={resource.href.startsWith("http") ? "_blank" : undefined} rel={resource.href.startsWith("http") ? "noopener" : undefined}>
              Ver recurso
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Sugerencias de recursos</p>
        <h2>Propón un recurso que realmente ayude</h2>
        <p>
          Si notas que falta un ejercicio, glosario, guía o laboratorio, envíame la idea con contexto.
          No todo se publicará de inmediato: primero revisaré si encaja con la ruta y si aporta valor real.
        </p>
      </div>
      <div class="formulario-contacto panel-contacto formulario-recursos" data-contact-panel data-context="Sugerencia de recurso">
        <div class="formulario-cabecera">
          <span>Recurso propuesto</span>
          <strong>Dime qué falta y para qué serviría</strong>
          <p>Mientras más concreto sea el problema, más fácil será convertirlo en una práctica útil para la comunidad.</p>
        </div>
        <div class="formulario-opciones">
          <label>
            Nombre
            <input type="text" name="nombre" autocomplete="name" maxlength="80" placeholder="Tu nombre" required />
          </label>
          <label>
            Correo
            <input type="email" name="correo" autocomplete="email" maxlength="120" placeholder="tu.correo@ejemplo.com" required />
          </label>
        </div>
        <label>
          Asunto
          <input type="text" name="asunto" maxlength="120" placeholder="Ejemplo: falta práctica de condicionales" required />
        </label>
        <div class="formulario-opciones">
          <label>
            Tema sugerido
            <input type="text" name="tema" maxlength="120" placeholder="Ejemplo: arreglos en Java" required />
          </label>
          <label>
            Tipo de recurso
            <select name="tipo" required>
              <option value="Ejercicio">Ejercicio</option>
              <option value="Reto">Reto</option>
              <option value="Glosario">Glosario</option>
              <option value="Guía">Guía</option>
              <option value="Laboratorio">Laboratorio</option>
            </select>
          </label>
        </div>
        <label>
          ¿Por qué debería estar en la ruta?
          <textarea name="motivo" rows="5" maxlength="700" data-countable placeholder="Explica qué problema ayudaría a resolver o qué tema falta reforzar." required></textarea>
        </label>
        <label class="confirmacion-datos">
          <input type="checkbox" name="confirmacion" required />
          <span>Confirmo que no estoy enviando datos personales, contraseñas ni información sensible.</span>
        </label>
        <small class="contador-caracteres" data-counter>0/700</small>
        <p class="nota-privacidad">Primero revisaré la utilidad, claridad, fuentes y relación con la ruta antes de convertir la idea en contenido público.</p>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-email>Enviar idea por correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
