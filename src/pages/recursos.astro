---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { resources } from "../data/recursos.js";
---

<BaseLayout title="Recursos | Chilete DevPath">
  <PageHero
    eyebrow="Recursos"
    title="Material para practicar, revisar y avanzar con criterio"
    description="Una biblioteca de ejercicios, retos, glosarios y guías para que la comunidad estudie sin depender de carpetas sueltas."
    variant="recursos"
    visualTitle="Biblioteca DevPath"
    visualText="Material preparado para estudiar, practicar y consultar."
    badges={["Ejercicios", "Glosarios", "Guías breves"]}
    stats={[
      { value: "Resolver", label: "antes de mirar solución" },
      { value: "Consultar", label: "conceptos clave" },
      { value: "Mejorar", label: "con práctica guiada" },
    ]}
    primaryAction={{ label: "Ver recursos", href: "#recursos" }}
    secondaryAction={{ label: "Abrir GitHub", href: "https://github.com/chiletedevpath/aprendizaje", external: true }}
  />

  <section id="recursos" class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Cómo usar esta sección"
        title="Elige si quieres resolver, estudiar o consultar"
        description="Cada recurso tiene un propósito concreto para que la comunidad no dependa solo de navegar carpetas en GitHub."
      />
      <div class="tarjetas tarjetas-4">
        {resources.map((resource) => (
          <article class="tarjeta recurso-card">
            <span class="estado">{resource.status}</span>
            <small>{resource.type}</small>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <a href={resource.href} target="_blank" rel="noopener">Ver recurso</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
