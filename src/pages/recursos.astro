---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { resources } from "../data/recursos.js";
---

<BaseLayout title="Recursos | Chilete DevPath">
  <PageHero
    eyebrow="Recursos"
    title="Practica, revisa y avanza con material organizado"
    description="Esta seccion debe funcionar como biblioteca de aprendizaje: ejercicios, retos, glosarios y criterios listos para consultar."
    variant="recursos"
    visualTitle="Biblioteca DevPath"
    visualText="Material preparado para estudiar, practicar y consultar."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Como usar esta seccion"
        title="Elige si quieres resolver, estudiar o consultar"
        description="Cada recurso tiene un proposito concreto para que la comunidad no dependa solo de navegar carpetas en GitHub."
      />
      <div class="tarjetas tarjetas-4">
        {resources.map((resource) => (
          <article class="tarjeta recurso-card">
            <span class="estado">{resource.status}</span>
            <small>{resource.type}</small>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <a href={resource.href} target="_blank" rel="noopener">Ver recurso</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
