---
import BaseLayout from "../layouts/BaseLayout.astro";
import PolicyIcon from "../components/PolicyIcon.astro";
import { policies } from "../data/recursos.js";
---

<BaseLayout title="Criterios | Chilete DevPath">
  <section class="seccion criterios-hero">
    <div class="contenedor criterios-hero-grid">
      <div class="criterios-hero-texto">
        <p class="etiqueta">Criterios de publicacion</p>
        <h1>Publicamos con criterio, no con prisa</h1>
        <p class="criterios-frase">Aprender tambien implica publicar con responsabilidad.</p>
        <p class="seccion-descripcion">
          Las politicas de Chilete DevPath protegen autoria, fuentes, privacidad, bienestar,
          uso responsable de IA y seguridad antes de convertir contenido en material publico.
        </p>
      </div>

      <aside class="criterios-resumen" aria-label="Resumen de criterios de publicacion">
        <strong>Antes de publicar</strong>
        <ul>
          <li>Autoria clara</li>
          <li>Fuentes revisadas</li>
          <li>Privacidad protegida</li>
          <li>Uso responsable de IA</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="politicas-grid">
        {policies.map((policy) => (
          <article class:list={["politica-documento", `politica-${policy.tone}`]}>
            <header class="politica-encabezado">
              <PolicyIcon name={policy.icon} />
              <div>
                <span class="politica-codigo">{policy.code}</span>
                <h3>{policy.title}</h3>
              </div>
            </header>
            <div class="politica-cuerpo">
              <p class="politica-destacado">{policy.highlight}</p>
              <p>{policy.objective}</p>

              <details class="politica-metadatos">
                <summary>Ver alcance y control</summary>
                <dl>
                  <div>
                    <dt>Alcance</dt>
                    <dd>{policy.scope}</dd>
                  </div>
                  <div>
                    <dt>Responsable</dt>
                    <dd>{policy.owner}</dd>
                  </div>
                  <div>
                    <dt>Estado</dt>
                    <dd><span class="estado-activo"></span>{policy.version} - {policy.status}</dd>
                  </div>
                </dl>
              </details>
            </div>
            <a class="boton boton-principal" href={policy.href} target="_blank" rel="noopener">Abrir politica</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
