---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import PolicyIcon from "../components/PolicyIcon.astro";
import { policies } from "../data/recursos.js";
---

<BaseLayout title="Criterios | Chilete DevPath">
  <section class="seccion criterios-hero">
    <div class="contenedor criterios-hero-grid">
      <div class="criterios-hero-texto">
        <Breadcrumb items={[{ label: "Inicio", href: "/" }, { label: "Criterios" }]} />
        <p class="etiqueta">Criterios de publicación</p>
        <h1>Publicamos con criterio, no con prisa</h1>
        <p class="criterios-frase">Aprender también implica publicar con responsabilidad.</p>
        <p class="seccion-descripcion">
          Las políticas de Chilete DevPath protegen autoría, fuentes, privacidad, bienestar,
          uso responsable de IA y seguridad antes de convertir contenido en material público.
        </p>
      </div>

      <div class="criterios-visual" aria-label="Sistema de criterios Chilete DevPath">
        <div class="criterios-visual-nucleo">
          <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
          <span>Chilete DevPath</span>
        </div>
        {policies.map((policy, index) => (
          <span class:list={["criterio-orbita", `criterio-orbita-${index + 1}`, `politica-${policy.tone}`]}>
            <PolicyIcon name={policy.icon} />
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <div class="politicas-grid">
        {policies.map((policy) => (
          <article class:list={["politica-documento", `politica-${policy.tone}`]}>
            <header class="politica-encabezado">
              <PolicyIcon name={policy.icon} />
              <div>
                <span class="politica-codigo">{policy.code}</span>
                <h3>{policy.title}</h3>
              </div>
            </header>
            <div class="politica-cuerpo">
              <p class="politica-destacado">{policy.highlight}</p>
              <p>{policy.objective}</p>

              <details class="politica-metadatos">
                <summary>Ver alcance y control</summary>
                <dl>
                  <div>
                    <dt>Alcance</dt>
                    <dd>{policy.scope}</dd>
                  </div>
                  <div>
                    <dt>Responsable</dt>
                    <dd>{policy.owner}</dd>
                  </div>
                  <div>
                    <dt>Estado</dt>
                    <dd><span class="estado-activo"></span>{policy.version} - {policy.status}</dd>
                  </div>
                </dl>
              </details>
            </div>
            <a class="boton boton-principal" href={policy.href} target="_blank" rel="noopener">Abrir política</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
