---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { academicProjects, projectAreas } from "../data/proyectos.js";
---

<BaseLayout title="Proyectos | Chilete DevPath">
  <PageHero
    eyebrow="Proyectos"
    title="Evidencia técnica sin confundir avance con portafolio"
    description="Cada proyecto se muestra con estado, contexto y criterio de publicación para proteger la marca y explicar el aprendizaje real."
    variant="proyectos"
    visualTitle="Dashboard de avance"
    visualText="Proyectos, aprendizaje y evidencia técnica en un solo sistema."
    imageSrc="/assets/img/editorial/adrian-devpath-proyectos-dashboard.jpg"
    imageAlt="Adrian Pisco trabajando en un entorno profesional de desarrollo para Chilete DevPath."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Mapa del ecosistema"
        title="Primero se aprende, luego se evidencia, después se selecciona"
        description="La web diferencia contenido de aprendizaje, evidencia académica y futuros proyectos de portafolio para no mezclar etapas."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreas.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Evidencia en proceso"
        title="Proyectos académicos en revisión"
        description="Estos proyectos se enlazan como avance técnico documentado. Aún no representan portafolio final ni casos listos para destacar."
      />
      <div class="tarjetas tarjetas-3">
        {academicProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
