---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { academicProjects, projectAreas } from "../data/proyectos.js";

const projectFilters = [
  { label: "Ruta completa", value: "todos" },
  { label: "Datos", value: "datos" },
  { label: "Software", value: "software" },
  { label: "Patrones", value: "patrones" },
  { label: "Backend", value: "backend" },
  { label: "Frontend", value: "frontend" },
  { label: "UTP", value: "utp" },
  { label: "Tecsup", value: "tecsup" },
];

const orderedAcademicProjects = [...academicProjects].sort((a, b) => a.routeOrder - b.routeOrder);
---

<BaseLayout title="Proyectos | Chilete DevPath">
  <PageHero
    eyebrow="Proyectos"
    title="Evidencia técnica sin confundir avance con portafolio"
    description="Aquí muestro mis proyectos con contexto: qué problema trabajan, qué aprendí, qué tecnologías usé y desde dónde puedes revisarlos."
    variant="proyectos"
    heroImage="/assets/img/heros/proyectos-chiletedevpath.webp"
    showVisual={false}
    visualTitle="Tablero de proyectos"
    visualText="Evidencia ordenada por ruta, avance y aprendizaje."
    visualItems={[
      { title: "Contexto", text: "Cada proyecto explica por qué existe." },
      { title: "Avance", text: "La barra muestra estado real, no apariencia." },
      { title: "Revisión", text: "El aprendizaje se resume con criterio técnico." },
    ]}
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Mapa del ecosistema"
        title="Primero se aprende, luego se evidencia, después se selecciona"
        description="No quiero mezclar ejercicios, entregas académicas y portafolio profesional. Cada espacio tiene una función para que mi avance se entienda sin inflarlo."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreas.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ruta de evidencia"
        title="Proyectos académicos ordenados por ruta"
        description="Estos proyectos se leen como una ruta: datos, construcción de software, patrones, backend y frontend. La institución sigue visible, pero el orden principal es el camino de aprendizaje."
      />
      <div class="filtros-recursos filtros-proyectos" aria-label="Filtros de proyectos académicos">
        {projectFilters.map((filter, index) => (
          <button
            class={index === 0 ? "filtro-recurso filtro-activo" : "filtro-recurso"}
            type="button"
            data-project-filter={filter.value}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {filter.label}
          </button>
        ))}
      </div>
      <div class="tarjetas tarjetas-3">
        {orderedAcademicProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
