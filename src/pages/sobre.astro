---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { site } from "../data/site.js";

const principles = [
  {
    title: "Origen",
    text: "Chilete representa el punto de partida: identidad, disciplina y una mirada local que no renuncia a crecer.",
  },
  {
    title: "Ruta",
    text: "DevPath representa el camino: aprender por etapas, practicar, revisar y construir evidencia.",
  },
  {
    title: "Criterio",
    text: "La marca no busca publicar por publicar. Cada contenido debe ser util, revisable y responsable.",
  },
];
---

<BaseLayout title="Sobre Chilete DevPath | Adrian Pisco">
  <PageHero
    eyebrow="Sobre Chilete DevPath"
    title="Una marca de aprendizaje técnico con origen, ruta y criterio"
    description="Chilete DevPath organiza aprendizaje, recursos, proyectos y políticas para convertir avance técnico en evidencia pública útil para la comunidad."
    variant="sobre"
    visualTitle="Chilete + DevPath"
    visualText="Origen local, camino técnico y publicación responsable."
  />

  <section class="seccion seccion-clara">
    <div class="contenedor sobre-marca-grid">
      <div>
        <p class="etiqueta">Que es Chilete DevPath</p>
        <h2>Una marca personal convertida en ruta publica de aprendizaje</h2>
        <p>
          Chilete DevPath organiza el avance técnico de Adrian Pisco como estudiante de Ingeniería de
          Sistemas e Informatica y futuro desarrollador Full Stack. Su valor no esta en mostrar todo,
          sino en ordenar lo que realmente ayuda a aprender.
        </p>
        <p>
          La web conecta ejercicios, proyectos académicos, recursos, políticas y comunidad para que otros
          estudiantes puedan seguir una ruta clara: comprender, practicar, construir, revisar y publicar
          con responsabilidad.
        </p>
        <div class="sobre-claves">
          <span>No es un repositorio suelto</span>
          <span>No es portafolio final improvisado</span>
          <span>Si es una ruta con evidencia y criterio</span>
        </div>
      </div>
      <div class="mapa-identidad">
        <span>Ubicacion de origen</span>
        <strong>{site.location}</strong>
        <p>La identidad territorial se usa como punto de partida de marca, no como apropiacion institucional.</p>
        <a class="boton boton-secundario" href={site.mapsHref} target="_blank" rel="noopener">Abrir mapa</a>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Diferencia de marca"
        title="La web debe explicar el camino, no decorar el camino"
        description="Cada seccion existe para orientar: aprender, practicar, evidenciar, publicar y compartir con responsabilidad."
      />
      <div class="tarjetas tarjetas-3">
        {principles.map((item) => (
          <article class="tarjeta valor-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
