---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout title="Sobre Chilete DevPath | Adrian Pisco">
  <PageHero
    eyebrow="Sobre Chilete DevPath"
    title="Origen, aprendizaje y criterio convertidos en marca"
    description="Chilete DevPath conecta mi historia personal con una ruta pública de aprendizaje, proyectos documentados y comunidad técnica."
    variant="sobre"
    visualTitle="Identidad DevPath"
    visualText="Una marca personal en construcción, con raíces y evidencia técnica."
    imageSrc="/assets/img/editorial/sobre-principal-candidato-v1.jpg"
    imageAlt="Retrato editorial de Adrian Pisco para Chilete DevPath."
    badges={["Chilete", "Full Stack", "Ingeniería de Sistemas"]}
    stats={[
      { value: "Raíces", label: "origen personal" },
      { value: "Ruta", label: "aprendizaje visible" },
      { value: "Criterio", label: "publicación responsable" },
    ]}
    primaryAction={{ label: "Ver ruta", href: "/ruta/" }}
    secondaryAction={{ label: "Ver proyectos", href: "/proyectos/" }}
  />

  <section class="seccion">
    <div class="contenedor sobre-aura sobre-aura-con-foto">
      <p class="aura-texto aura-uno">Soy Adrian Pisco, estudiante de Ingeniería de Sistemas e Informática.</p>
      <p class="aura-texto aura-dos">Chilete DevPath representa mi ruta como futuro desarrollador Full Stack.</p>
      <figure class="sobre-persona-foto">
        <img
          src="/assets/img/editorial/sobre-principal-candidato-v1.jpg"
          width="1024"
          height="1536"
          alt="Retrato editorial de Adrian Pisco para Chilete DevPath."
        />
      </figure>
      <p class="aura-texto aura-tres">También expresa mi camino como futuro ingeniero de sistemas.</p>
      <p class="aura-texto aura-cuatro">Mis raíces en Chilete se conectan con aprendizaje técnico, práctica y comunidad.</p>
      <p class="aura-texto aura-cinco">Cada avance busca convertirse en evidencia real, recurso útil y criterio profesional.</p>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor bloque-trabajo">
      <div>
        <p class="etiqueta">Forma de trabajo</p>
        <h2>Aprender, practicar, ordenar y compartir</h2>
        <p>
          Chilete DevPath no se construye como una vitrina vacía. Cada avance debe pasar por
          práctica, documentación, criterio de publicación y revisión antes de convertirse en
          contenido útil para la comunidad.
        </p>
      </div>
      <figure class="bloque-trabajo-imagen">
        <img
          src="/assets/img/editorial/sobre-proceso-candidato-v1.jpg"
          width="1792"
          height="1024"
          alt="Adrian Pisco documentando y practicando como parte de Chilete DevPath."
        />
      </figure>
    </div>
  </section>
</BaseLayout>
