---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { site } from "../data/site.js";

const principles = [
  {
    title: "Origen",
    text: "Chilete está en el nombre porque representa mi punto de partida. No es un adorno: es la raíz desde donde estoy construyendo esta marca.",
  },
  {
    title: "Ruta",
    text: "DevPath representa el camino: aprender por etapas, practicar, revisar y convertir el avance en algo que otros también puedan usar.",
  },
  {
    title: "Criterio",
    text: "No quiero publicar por publicar. Cada contenido debe entenderse, revisarse y aportar algo real a quien está aprendiendo.",
  },
];
---

<BaseLayout title="Sobre Chilete DevPath | Adrian Pisco">
  <PageHero
    eyebrow="Sobre Chilete DevPath"
    title="Una marca de aprendizaje técnico con origen, ruta y criterio"
    description="Chilete DevPath es la forma en la que estoy ordenando lo que aprendo para que otros estudiantes puedan seguir una ruta más clara, práctica y responsable."
    variant="sobre"
    heroImage="/assets/img/heros/sobre-chiletedevpath.png"
    showVisual={false}
    visualTitle="Origen y ruta"
    visualText="Chilete representa el punto de partida; DevPath, el camino técnico."
    visualItems={[
      { title: "Chilete", text: "Identidad de origen y raíz personal." },
      { title: "DevPath", text: "Aprendizaje por etapas y práctica constante." },
      { title: "Criterio", text: "Publicar solo lo que puede entenderse y revisarse." },
    ]}
  />

  <section class="seccion seccion-editorial">
    <div class="contenedor editorial-bloque editorial-bloque-invertido">
      <figure class="editorial-imagen">
        <img src="/assets/img/editorial/hero-inicio-candidato-v1.jpg" alt="Adrian Pisco en un espacio de trabajo profesional" loading="lazy" />
      </figure>
      <div class="editorial-frase">
        <p class="etiqueta">Marca en crecimiento</p>
        <blockquote>Chilete DevPath seguirá creciendo cada vez que un tema se explique mejor y ayude a alguien más.</blockquote>
        <p>
          La marca no nace para aparentar avance, sino para ordenar el camino y convertir el aprendizaje
          en material claro, revisable y útil para la comunidad.
        </p>
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor sobre-marca-grid">
      <div>
        <p class="etiqueta">Qué es Chilete DevPath</p>
        <h2>Una ruta pública para aprender, practicar y publicar con criterio</h2>
        <p>
          Chilete DevPath no es una carpeta bonita ni una lista de enlaces. Es mi manera de ordenar el aprendizaje:
          qué estudio, qué practico, qué proyecto construyo y qué puedo compartir sin perder contexto.
        </p>
        <p>
          La idea es simple: si algo me sirve para aprender, también puede servirle a otra persona si está bien explicado,
          revisado y publicado con respeto por las fuentes, la privacidad y la autoría.
        </p>
        <div class="sobre-claves">
          <span>Ruta antes que desorden</span>
          <span>Evidencia antes que apariencia</span>
          <span>Comunidad antes que vitrina</span>
        </div>
      </div>
      <div class="mapa-identidad">
        <span>Origen de la marca</span>
        <strong>{site.location}</strong>
        <div class="mapa-embed" aria-label="Mapa de referencia de Chilete, Contumazá, Cajamarca, Perú">
          <iframe
            title="Mapa de Chilete, Contumazá, Cajamarca, Perú"
            src="https://www.google.com/maps?q=Chilete,%20Contumaz%C3%A1,%20Cajamarca,%20Per%C3%BA&output=embed"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
        <p>
          Chilete es mi origen personal. Lo uso como identidad de marca, no como representación oficial
          de ninguna institución, municipalidad o entidad externa.
        </p>
        <a class="boton boton-secundario boton-mapa" href={site.mapsHref} target="_blank" rel="noopener noreferrer">
          Ver ubicación de referencia
        </a>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Diferencia de marca"
        title="La marca tiene que ayudar a entender el camino"
        description="Cada sección debe responder una pregunta concreta: por dónde empiezo, qué practico, qué proyecto reviso y qué criterio uso antes de publicar."
      />
      <div class="tarjetas tarjetas-3">
        {principles.map((item) => (
          <article class="tarjeta valor-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
