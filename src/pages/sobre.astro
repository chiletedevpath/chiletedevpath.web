---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout title="Sobre Chilete DevPath | Adrian Pisco">
  <PageHero
    eyebrow="Sobre Chilete DevPath"
    title="Una marca para aprender, construir y compartir con criterio"
    description="Chilete DevPath organiza aprendizaje, proyectos, recursos y criterios de publicacion para convertir el avance tecnico en contenido util para la comunidad."
    variant="sobre"
    showVisual={false}
  />

  <section class="seccion">
    <div class="contenedor sobre-aura sobre-aura-con-foto">
      <p class="aura-texto aura-uno">Chilete DevPath nace como una ruta publica de aprendizaje tecnico.</p>
      <p class="aura-texto aura-dos">Su proposito es ordenar ejercicios, proyectos y recursos con una secuencia clara.</p>
      <figure class="sobre-persona-foto">
        <img
          src="/assets/img/editorial/sobre-principal-candidato-v1.jpg"
          width="1024"
          height="1536"
          alt="Imagen editorial asociada a la marca Chilete DevPath."
        />
      </figure>
      <p class="aura-texto aura-tres">La marca conecta origen, practica, documentacion y comunidad.</p>
      <p class="aura-texto aura-cuatro">Cada contenido debe poder revisarse, entenderse y reutilizarse con criterio.</p>
      <p class="aura-texto aura-cinco">El objetivo es que aprender tambien signifique publicar responsablemente.</p>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor bloque-trabajo">
      <div>
        <p class="etiqueta">Forma de trabajo</p>
        <h2>Aprender, practicar, ordenar y compartir</h2>
        <p>
          Chilete DevPath no se construye como una vitrina vacia. Cada avance debe pasar por
          practica, documentacion, criterio de publicacion y revision antes de convertirse en
          contenido util para la comunidad.
        </p>
      </div>
      <figure class="bloque-trabajo-imagen">
        <img
          src="/assets/img/editorial/sobre-proceso-candidato-v1.jpg"
          width="1792"
          height="1024"
          alt="Proceso de practica y documentacion para Chilete DevPath."
        />
      </figure>
    </div>
  </section>
</BaseLayout>
