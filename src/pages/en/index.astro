---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { valuePropsEn } from "../../data/site.js";

const metricsEn = [
  { label: "Available topics", value: "11", detail: "Path from fundamentals to backend" },
  { label: "Academic projects", value: "3", detail: "Evidence with status and progress" },
  { label: "Active policies", value: "4", detail: "Publishing, AI, wellbeing and authorship" },
  { label: "Active paths", value: "4", detail: "Foundation, software, web-data and specialization" },
];

const audienceEn = [
  "Students starting programming who need a clear path.",
  "People who want to practice with exercises before jumping into projects.",
  "Developers in training who want to document and publish better.",
  "Community members looking for real examples without losing technical judgment.",
];
---

<BaseLayout title="Chilete DevPath | Learning path">
  <PageHero
    eyebrow="Chilete, Cajamarca, Peru | Full Stack Development"
    title="A public learning path built with practice and criteria"
    description="Chilete DevPath organizes learning, academic evidence, resources and publishing criteria for students who want to grow with order."
    variant="ruta"
    visualTitle="Learning path"
    visualText="From fundamentals to real projects."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Why Chilete DevPath"
        title="Learning is not collecting folders. It is building judgment."
        description="The ecosystem explains what to practice, what to review and how to publish technical progress responsibly."
      />
      <div class="tarjetas tarjetas-4">
        {valuePropsEn.map((item) => (
          <article class="tarjeta valor-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Who it is for"
        title="A website for guided learning, practice and context"
        description="Chilete DevPath is designed for people who want to move step by step and understand why each piece of content exists."
      />
      <div class="tarjetas tarjetas-4">
        {audienceEn.map((item) => (
          <article class="tarjeta audiencia-card">
            <span class="estado">DevPath</span>
            <p>{item}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor metricas-panel">
      <div>
        <p class="etiqueta">Ecosystem status</p>
        <h2>Real indicators of published progress</h2>
        <p>These metrics summarize available content and change only when the path, projects or policies are verifiably updated.</p>
      </div>
      <div class="metricas-grid">
        {metricsEn.map((metric) => (
          <article class="metrica-card">
            <strong data-count={metric.value}>{metric.value}</strong>
            <span>{metric.label}</span>
            <small>{metric.detail}</small>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
