---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import PolicyIcon from "../../components/PolicyIcon.astro";
import { policiesEn } from "../../data/recursos.js";
---

<BaseLayout title="Criteria | Chilete DevPath">
  <PageHero
    eyebrow="Publishing criteria"
    title="We publish with judgment, not with rush"
    description="Before a resource, project or guide becomes public, it must have context, respect authorship and avoid exposing sensitive data. That is the difference between publishing content and building trust."
    variant="criterios"
    heroImage="/assets/img/heros/criterios-chiletedevpath.png"
    showVisual={false}
    visualTitle="Review before publishing"
    visualText="An editorial filter for authorship, privacy and responsible use."
    visualItems={[
      { title: "Authorship", text: "Recognize origin, sources and limits of the material." },
      { title: "Privacy", text: "Avoid personal data or sensitive information." },
      { title: "Responsibility", text: "Use AI and external resources with judgment." },
    ]}
  />

  <section class="seccion">
    <div class="contenedor">
      <div class="politicas-grid">
        {policiesEn.map((policy) => (
          <article class:list={["politica-documento", `politica-${policy.tone}`]}>
            <header class="politica-encabezado">
              <PolicyIcon name={policy.icon} />
              <div>
                <span class="politica-codigo">{policy.code}</span>
                <h3>{policy.title}</h3>
              </div>
            </header>
            <div class="politica-cuerpo">
              <p class="politica-destacado">{policy.highlight}</p>
              <p>{policy.objective}</p>
              <details class="politica-metadatos">
                <summary>View policy metadata</summary>
                <dl>
                  <div>
                    <dt>Scope</dt>
                    <dd>{policy.scope}</dd>
                  </div>
                  <div>
                    <dt>Responsible</dt>
                    <dd>{policy.owner}</dd>
                  </div>
                  <div>
                    <dt>Status</dt>
                    <dd><span class="estado-activo"></span>{policy.version} - {policy.status}</dd>
                  </div>
                </dl>
              </details>
            </div>
            <a class="boton boton-principal" href={policy.href}>Open policy</a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
