---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { resourcesEn } from "../../data/recursos.js";

const resourceFilters = [
  { label: "All", value: "todos" },
  { label: "Exercises", value: "exercises" },
  { label: "Challenges", value: "challenges" },
  { label: "Glossary", value: "glossary" },
  { label: "Guides", value: "guides" },
  { label: "Java", value: "java" },
  { label: "Web", value: "web" },
  { label: "SQL", value: "sql" },
];
---

<BaseLayout title="Resources | Chilete DevPath">
  <PageHero
    eyebrow="Resources"
    title="Practice, review and move forward with organized material"
    description="This section helps students find what to solve, what to review and what to consult without guessing inside folders."
    variant="recursos"
    heroImage="/assets/img/heros/recursos-chiletedevpath.png"
    showVisual={false}
    visualTitle="Practice library"
    visualText="Exercises, challenges, guides and glossaries connected to the path."
    visualItems={[
      { title: "Solve", text: "Practice before looking at a solution." },
      { title: "Study", text: "Review solved exercises with calm." },
      { title: "Consult", text: "Use glossaries and guides when context is missing." },
    ]}
  />

  <section class="seccion seccion-editorial">
    <div class="contenedor editorial-bloque">
      <div class="editorial-frase">
        <p class="etiqueta">Intentional material</p>
        <blockquote>A resource is useful when it helps you try, make mistakes, review and try again with more clarity.</blockquote>
        <p>
          Exercises, glossaries and guides should support the learning process. This is not about collecting links,
          but about having concrete support to move forward with order.
        </p>
      </div>
      <figure class="editorial-imagen">
        <img src="/assets/img/editorial/ChatGPT Image 26 jun 2026, 03_07_19 a.m..png" alt="Adrian Pisco explaining the learning path" loading="lazy" />
      </figure>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="How to use this section"
        title="Choose a resource according to your learning moment"
        description="If you want to practice, open challenges. If you already tried, review solved exercises. If a concept is unclear, use the glossary as support."
      />
      <div class="filtros-recursos" aria-label="Resource filters">
        {resourceFilters.map((filter, index) => (
          <button
            class={index === 0 ? "filtro-recurso filtro-activo" : "filtro-recurso"}
            type="button"
            data-resource-filter={filter.value}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {filter.label}
          </button>
        ))}
      </div>
      <div class="tarjetas tarjetas-4">
        {resourcesEn.map((resource) => (
          <article class="tarjeta recurso-card" data-resource-category={resource.category} data-resource-tags={resource.tags?.join(" ")}>
            <span class="estado">{resource.status}</span>
            <small>{resource.type}</small>
            <h3>{resource.title}</h3>
            <p>{resource.description}</p>
            <dl class="recurso-meta">
              <div>
                <dt>Level</dt>
                <dd>{resource.level}</dd>
              </div>
              <div>
                <dt>Topic</dt>
                <dd>{resource.topic}</dd>
              </div>
              <div>
                <dt>Time</dt>
                <dd>{resource.time}</dd>
              </div>
            </dl>
            <a href={resource.href} target={resource.href.startsWith("http") ? "_blank" : undefined} rel={resource.href.startsWith("http") ? "noopener" : undefined}>
              Open resource
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Resource suggestions</p>
        <h2>Suggest a resource that would really help</h2>
        <p>
          If a topic needs an exercise, glossary entry, guide or lab, send the idea with context.
          I review whether it fits the path before turning it into public material.
        </p>
      </div>
      <div class="formulario-contacto panel-contacto formulario-recursos" data-contact-panel data-context="Resource suggestion">
        <div class="formulario-cabecera">
          <span>Proposed resource</span>
          <strong>Tell me what is missing and why it matters</strong>
          <p>The clearer the problem is, the easier it is to turn it into useful practice for the community.</p>
        </div>
        <div class="formulario-opciones">
          <label>
            Name
            <input type="text" name="nombre" autocomplete="name" maxlength="80" placeholder="Your name" required />
          </label>
          <label>
            Email
            <input type="email" name="correo" autocomplete="email" maxlength="120" placeholder="your.email@example.com" required />
          </label>
        </div>
        <label>
          Subject
          <input type="text" name="asunto" maxlength="120" placeholder="Example: missing conditionals practice" required />
        </label>
        <div class="formulario-opciones">
          <label>
            Suggested topic
            <input type="text" name="tema" maxlength="120" placeholder="Example: Java arrays" required />
          </label>
          <label>
            Resource type
            <select name="tipo" required>
              <option value="Exercise">Exercise</option>
              <option value="Challenge">Challenge</option>
              <option value="Glossary">Glossary</option>
              <option value="Guide">Guide</option>
              <option value="Lab">Lab</option>
            </select>
          </label>
        </div>
        <label>
          Why should it be part of the path?
          <textarea name="motivo" rows="5" maxlength="700" data-countable placeholder="Explain what problem it helps solve or what topic needs reinforcement." required></textarea>
        </label>
        <label class="confirmacion-datos">
          <input type="checkbox" name="confirmacion" required />
          <span>I confirm I am not sending personal data, passwords or sensitive information.</span>
        </label>
        <small class="contador-caracteres" data-counter>0/700</small>
        <p class="nota-privacidad">I review usefulness, clarity, sources and relation with the path before turning the idea into public content.</p>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-email>Prepare email</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
