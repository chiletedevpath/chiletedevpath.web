---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import { academicProjectsEn, projectAreasEn } from "../../data/proyectos.js";

const projectFilters = [
  { label: "Full path", value: "todos" },
  { label: "Data", value: "datos" },
  { label: "Software", value: "software" },
  { label: "Patterns", value: "patrones" },
  { label: "Backend", value: "backend" },
  { label: "Frontend", value: "frontend" },
  { label: "UTP", value: "utp" },
  { label: "Tecsup", value: "tecsup" },
];

const orderedAcademicProjects = [...academicProjectsEn].sort((a, b) => a.routeOrder - b.routeOrder);
---

<BaseLayout title="Projects | Chilete DevPath">
  <PageHero
    eyebrow="Projects"
    title="Technical evidence without confusing progress with portfolio"
    description="Projects are shown with context: what problem they address, what I learned, which technologies I used and where you can review them."
    variant="proyectos"
    heroImage="/assets/img/heros/proyectos-chiletedevpath.webp"
    showVisual={false}
    visualTitle="Project board"
    visualText="Evidence organized by path, progress and learning."
    visualItems={[
      { title: "Context", text: "Each project explains why it exists." },
      { title: "Progress", text: "The bar shows real status, not appearance." },
      { title: "Review", text: "Learning is summarized with technical judgment." },
    ]}
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Ecosystem map"
        title="Each space has a clear role"
        description="Learning is for practice, academia is for evidence and portfolio is for a future professional selection."
      />
      <div class="tarjetas tarjetas-3">
        {projectAreasEn.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Evidence path"
        title="Academic projects ordered by path"
        description="These projects read as a path: data, software construction, patterns, backend and frontend. Institution remains visible, but the main order is the learning journey."
      />
      <div class="filtros-recursos filtros-proyectos" aria-label="Academic project filters">
        {projectFilters.map((filter, index) => (
          <button
            class={index === 0 ? "filtro-recurso filtro-activo" : "filtro-recurso"}
            type="button"
            data-project-filter={filter.value}
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {filter.label}
          </button>
        ))}
      </div>
      <div class="tarjetas tarjetas-3">
        {orderedAcademicProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</BaseLayout>
