---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PolicyIcon from "../../../components/PolicyIcon.astro";
import { policiesEn } from "../../../data/recursos.js";

export function getStaticPaths() {
  return policiesEn.map((policy) => ({
    params: { slug: policy.slug },
    props: { policy },
  }));
}

const { policy } = Astro.props;
---

<BaseLayout title={`${policy.title} | Chilete DevPath`}>
  <section class:list={["seccion", "politica-detalle-hero", `politica-${policy.tone}`]}>
    <div class="contenedor politica-detalle-grid">
      <div>
        <a class="enlace-retorno" href="/en/politicas/" aria-label="Return to the policy list">
          Back to policies: return to the list
        </a>
        <p class="etiqueta">{policy.code}</p>
        <h1>{policy.title}</h1>
        <p class="politica-destacado">{policy.highlight}</p>
      </div>
      <div class="politica-sello">
        <PolicyIcon name={policy.icon} />
        <span>Active document</span>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor politica-documento-formal">
      <header class="politica-formal-encabezado">
        <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
        <div>
          <strong>Chilete DevPath</strong>
          <span>Internal policy system</span>
        </div>
      </header>

      <div class="politica-tabla">
        <div>
          <span>Code</span>
          <strong>{policy.code}</strong>
        </div>
        <div>
          <span>Version</span>
          <strong>{policy.version}</strong>
        </div>
        <div>
          <span>Status</span>
          <strong>{policy.status}</strong>
        </div>
        <div>
          <span>Owner</span>
          <strong>{policy.owner}</strong>
        </div>
      </div>

      <article>
        <h2>1. Objective</h2>
        <p>{policy.objective}</p>
      </article>

      <article>
        <h2>2. Scope</h2>
        <p>{policy.scope}</p>
      </article>

      <article>
        <h2>3. Responsibilities</h2>
        <ul>
          <li>Apply this policy before publishing content on the website, GitHub or official channels.</li>
          <li>Review authorship, privacy, academic context and security before publication.</li>
          <li>Update this policy when the Chilete DevPath ecosystem changes scope.</li>
        </ul>
      </article>

      <article>
        <h2>4. Guidelines</h2>
        <ul>
          {policy.principles.map((principle) => <li>{principle}</li>)}
        </ul>
      </article>

      <article>
        <h2>5. Version Control</h2>
        <div class="politica-version-control">
          <span>Version {policy.version}</span>
          <p>Active document for the public Chilete DevPath website.</p>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
