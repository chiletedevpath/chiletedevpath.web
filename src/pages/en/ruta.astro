---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import RouteStage from "../../components/RouteStage.astro";
import TechIcon from "../../components/TechIcon.astro";
import { routeStagesEn, techStack } from "../../data/ruta.js";
---

<BaseLayout title="Learning Path | Chilete DevPath">
  <PageHero
    eyebrow="Learning path"
    title="Start with fundamentals and move forward with real practice"
    description="This path organizes what to understand first, what to practice next and how to connect progress with real projects."
    variant="ruta"
    visualTitle="Progressive learning path"
    visualText="Clean visual sequence without overlaid text."
  />

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Guided stages"
        title="A route from foundation to production habits"
        description="Each block links to the learning repository and shows the expected result of that stage."
      />
      <div class="ruta-etapas">
        {routeStagesEn.map((stage) => <RouteStage stage={stage} />)}
      </div>
      <div class="ruta-accion">
        <p>The practical content lives in the learning repository. I will keep expanding it with useful exercises, focused glossaries and labs when they truly help people learn.</p>
        <a class="boton boton-principal" href="https://github.com/chiletedevpath/aprendizaje" target="_blank" rel="noopener">
          Open learning repository
        </a>
      </div>
    </div>
  </section>

  <section class="seccion">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Technologies in practice"
        title="Tools used across the path"
        description="Each technology appears because it solves something in the route, not as decoration."
      />
      <div class="tech-grid">
        {techStack.map((tech) => (
          <a
            class={`tech-badge tech-${tech.tone}`}
            href={tech.href}
            target="_blank"
            rel="noopener"
            aria-label={`Open learning content related to ${tech.name}`}
          >
            <span class="tech-icono"><TechIcon name={tech.name} /></span>
            <div>
              <strong>{tech.name}</strong>
              <p>{tech.descriptionEn ?? tech.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
