---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { socials } from "../data/site.js";
---

<BaseLayout title="Comunidad | Chilete DevPath">
  <PageHero
    eyebrow="Comunidad"
    title="Aprender acompañado hace el camino más sostenible"
    description="Quiero que Chilete DevPath también sea un espacio para conversar sobre aprendizaje, compartir avances y mejorar la ruta con aportes reales."
    variant="comunidad"
    visualTitle="Comunidad conectada"
    visualText="Canales oficiales y aportes revisados."
  />

  <section class="seccion contacto">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Canales oficiales"
        title="Sigue el avance por el canal que uses mejor"
        description="GitHub conserva el código y la evidencia. Las redes me sirven para explicar el proceso con un lenguaje más cercano y compartir avances de la marca."
      />
      <div class="redes" aria-label="Canales oficiales de Chilete DevPath">
        {socials.map((social) => (
          <a class={social.primary ? "red-social red-social-principal" : "red-social"} href={social.href} target="_blank" rel="noopener">
            <SocialIcon name={social.name} />
            <span>{social.label}</span>
            <strong>{social.name}</strong>
            <small>{social.description}</small>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="seccion seccion-clara">
    <div class="contenedor contacto-grid">
      <div>
        <p class="etiqueta">Feedback de comunidad</p>
        <h2>Cuéntame qué mejorarías y por qué</h2>
        <p>
          Si encuentras un tema confuso, una sección incompleta o una idea que podría ayudar a más estudiantes,
          puedes enviármela por correo. Prefiero revisar cada aporte antes de convertirlo en contenido público.
        </p>
      </div>
      <div class="formulario-contacto panel-contacto formulario-feedback" data-contact-panel data-context="Feedback de comunidad">
        <div class="formulario-cabecera">
          <span>Mejora revisada</span>
          <strong>Ayúdame a mejorar la ruta con contexto</strong>
          <p>No busco comentarios sueltos. Busco ideas claras: qué viste, qué problema genera y cómo podría ayudar a la comunidad.</p>
        </div>
        <div class="formulario-opciones">
          <label>
            Nombre
            <input type="text" name="nombre" autocomplete="name" placeholder="Tu nombre" required />
          </label>
          <label>
            Correo
            <input type="email" name="correo" autocomplete="email" placeholder="tu.correo@ejemplo.com" required />
          </label>
        </div>
        <label>
          Tipo de aporte
          <select name="tipo" required>
            <option value="Mejora de contenido">Mejora de contenido</option>
            <option value="Mejora visual">Mejora visual</option>
            <option value="Error detectado">Error detectado</option>
            <option value="Idea para comunidad">Idea para comunidad</option>
          </select>
        </label>
        <label>
          Sugerencia
          <textarea name="sugerencia" rows="5" maxlength="700" data-countable placeholder="Describe qué mejorarías, dónde lo viste y por qué ayudaría a la comunidad." required></textarea>
        </label>
        <small class="contador-caracteres" data-counter>0/700</small>
        <p class="nota-privacidad">Por ahora no habrá comentarios públicos. Primero necesito un sistema de moderación y seguridad para evitar spam, exposición de datos o contenido fuera de contexto.</p>
        <div class="acciones-formulario">
          <button class="boton boton-principal" type="button" data-send-email>Enviar sugerencia por correo</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
