---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SocialIcon from "../components/SocialIcon.astro";
import { socials } from "../data/site.js";
---

<BaseLayout title="Comunidad | Chilete DevPath">
  <PageHero
    eyebrow="Comunidad"
    title="Aprender acompañado hace el camino más sostenible"
    description="Los canales de Chilete DevPath sirven para compartir avances, resolver dudas, mostrar práctica y construir comunidad con criterio."
    variant="comunidad"
    visualTitle="Comunidad activa"
    visualText="Canales para compartir avance, dudas y aprendizaje responsable."
    badges={["Discord", "GitHub", "Redes oficiales"]}
    stats={[
      { value: "Código", label: "en GitHub" },
      { value: "Proceso", label: "en redes" },
      { value: "Comunidad", label: "en Discord" },
    ]}
    primaryAction={{ label: "Unirme a Discord", href: "https://discord.gg/4XsXRT4rG", external: true }}
    secondaryAction={{ label: "Explorar GitHub", href: "https://github.com/chiletedevpath", external: true }}
  />

  <section class="seccion contacto">
    <div class="contenedor">
      <SectionHeader
        eyebrow="Canales oficiales"
        title="Sigue el avance por el canal que uses mejor"
        description="GitHub conserva la evidencia técnica. Las redes ayudan a compartir proceso, avances, ideas y comunidad."
      />
      <div class="redes" aria-label="Canales oficiales de Chilete DevPath">
        {socials.map((social) => (
          <a class={social.primary ? "red-social red-social-principal" : "red-social"} href={social.href} target="_blank" rel="noopener">
            <SocialIcon name={social.name} />
            <span>{social.label}</span>
            <strong>{social.name}</strong>
            <small>{social.description}</small>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
