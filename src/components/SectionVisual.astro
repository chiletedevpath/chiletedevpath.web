---
const {
  variant = "ruta",
  title = "Visual Chilete DevPath",
  visualLabel = "Mapa de avance",
  visualHeadline = "De fundamentos a proyectos",
} = Astro.props;
---

<div class={`section-visual section-visual-${variant}`} aria-label={title}>
  {variant === "ruta" && (
    <div class="ruta-escena" role="img" aria-label={title}>
      <img
        class="ruta-imagen"
        src="/assets/img/heros/ruta-aprendizaje-camino-chilete.png"
        alt=""
        loading="eager"
        decoding="async"
      />
      <div class="ruta-capa"></div>
      <div class="ruta-panel">
        <span>{visualLabel}</span>
        <strong>{visualHeadline}</strong>
      </div>
      <svg class="ruta-overlay" viewBox="0 0 720 460" aria-hidden="true">
        <defs>
          <filter id="ruta-resplandor" x="-30%" y="-30%" width="160%" height="160%">
            <feGaussianBlur stdDeviation="5" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <path
          class="ruta-overlay-sombra"
          d="M398 456 C462 438 520 410 584 382 C632 360 680 344 642 310"
        />
        <path
          class="ruta-overlay-linea"
          d="M398 456 C462 438 520 410 584 382 C632 360 680 344 642 310"
          filter="url(#ruta-resplandor)"
          pathLength="1"
        />
        {[
          { n: "01", x: 398, y: 456, delay: "0s" },
          { n: "02", x: 512, y: 414, delay: "1.1s" },
          { n: "03", x: 604, y: 376, delay: "2.2s" },
          { n: "04", x: 682, y: 348, delay: "3.3s" },
          { n: "05", x: 642, y: 310, delay: "4.4s" },
        ].map((item) => (
          <g class="ruta-overlay-nodo" style={`--delay:${item.delay};`}>
            <circle cx={item.x} cy={item.y} r="20" />
            <text x={item.x} y={item.y + 1}>{item.n}</text>
          </g>
        ))}
      </svg>
    </div>
  )}
  {variant !== "ruta" && (
  <svg viewBox="0 0 720 460" role="img" aria-labelledby={`visual-${variant}-title`}>
    <title id={`visual-${variant}-title`}>{title}</title>
    <defs>
      <linearGradient id={`trazo-${variant}`} x1="0" x2="1" y1="1" y2="0">
        <stop offset="0%" stop-color="var(--color-raiz)" />
        <stop offset="48%" stop-color="var(--color-progreso)" />
        <stop offset="100%" stop-color="var(--color-acento)" />
      </linearGradient>
      <radialGradient id={`brillo-${variant}`} cx="70%" cy="18%" r="70%">
        <stop offset="0%" stop-color="rgba(255,255,255,.22)" />
        <stop offset="58%" stop-color="rgba(255,255,255,.05)" />
        <stop offset="100%" stop-color="rgba(255,255,255,0)" />
      </radialGradient>
      <filter id={`resplandor-${variant}`} x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="4" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    <rect class="visual-fondo" x="0" y="0" width="720" height="460" rx="30" />
    <rect class="visual-brillo" x="0" y="0" width="720" height="460" rx="30" fill={`url(#brillo-${variant})`} />
    <path class="visual-malla" d="M70 374 C168 302 238 330 326 250 C408 176 518 142 656 76" />

    {variant === "ruta" && (
      <g class="visual-ruta">
        <path class="visual-cerros visual-cerros-fondo" d="M0 288 C90 224 164 238 242 190 C326 138 418 168 500 118 C584 66 650 90 720 46" />
        <path class="visual-cerros visual-cerros-frente" d="M0 354 C124 278 220 306 332 244 C452 178 560 172 720 108" />
        <path class="visual-ladera" d="M0 376 C132 294 250 332 366 268 C480 206 570 176 720 132 L720 460 L0 460Z" />
        <path class="visual-carretera-sombra" d="M74 392 C164 328 216 322 282 260 C342 204 362 154 430 126 C502 96 568 78 656 34" />
        <path class="visual-carretera" d="M74 392 C164 328 216 322 282 260 C342 204 362 154 430 126 C502 96 568 78 656 34" filter={`url(#resplandor-${variant})`} />
        {[1, 2, 3, 4, 5].map((step, index) => {
          const points = [
            [112, 370],
            [252, 284],
            [372, 174],
            [508, 98],
            [640, 50],
          ];
          const [cx, cy] = points[index];
          return (
            <g class="visual-hito">
              <circle cx={cx} cy={cy} r="24" />
              <text x={cx} y={cy + 1}>{String(step).padStart(2, "0")}</text>
            </g>
          );
        })}
        <path class="visual-flecha" d="M632 48l-34-2m34 2-14 30" />
      </g>
    )}

    {variant === "proyectos" && (
      <g class="visual-proyectos">
        <rect class="visual-panel" x="86" y="92" width="548" height="290" rx="24" />
        <path class="visual-linea" d="M130 162h150M130 208h104M130 254h170" />
        <g class="visual-kanban">
          {[0, 1, 2].map((index) => {
            const x = 318 + index * 92;
            return (
              <g>
                <rect x={x} y="140" width="70" height="132" rx="14" />
                <path d={`M${x + 18} ${170 + index * 12}h34M${x + 18} ${196 + index * 12}h24`} />
              </g>
            );
          })}
        </g>
        <path class="visual-camino" d="M118 326 C214 282 314 304 408 244 C494 190 554 174 646 142" filter={`url(#resplandor-${variant})`} />
        <g class="visual-medidor">
          <circle cx="584" cy="302" r="46" />
          <path d="M562 304l18 18 40-52" />
        </g>
      </g>
    )}

    {variant === "recursos" && (
      <g class="visual-recursos">
        <rect class="visual-panel" x="92" y="92" width="536" height="284" rx="24" />
        <path class="visual-linea" d="M132 320h456" />
        {[0, 1, 2, 3].map((index) => {
          const x = 138 + index * 106;
          const y = 148 - (index % 2) * 18;
          return (
            <g class="visual-recurso">
              <rect x={x} y={y} width="68" height={138 + (index % 2) * 18} rx="14" />
              <path d={`M${x + 18} ${y + 36}h32M${x + 18} ${y + 66}h22`} />
            </g>
          );
        })}
        <circle class="visual-lupa" cx="540" cy="162" r="34" />
        <path class="visual-lupa-linea" d="M564 186l42 42" />
        <path class="visual-camino" d="M110 360 C196 320 300 338 390 286 C468 242 528 238 624 206" />
      </g>
    )}

    {variant === "criterios" && (
      <g class="visual-criterios">
        <rect class="visual-panel" x="108" y="72" width="280" height="318" rx="22" />
        {[132, 208, 284].map((y) => (
          <g class="visual-checkline">
            <path d={`M146 ${y + 12}l18 18 34-46`} />
            <path d={`M232 ${y}h104M232 ${y + 30}h72`} />
          </g>
        ))}
        <path class="visual-escudo" d="M506 102 604 142v78c0 66-38 110-98 136-60-26-98-70-98-136v-78Z" />
        <path class="visual-check" d="M464 234l32 32 70-88" />
        <path class="visual-camino" d="M92 398 C210 350 320 358 430 300 C512 258 582 224 662 170" />
      </g>
    )}

    {variant === "comunidad" && (
      <g class="visual-comunidad">
        <path class="visual-plaza" d="M164 310 C224 244 304 216 388 226 C468 236 540 282 586 348" />
        <path class="visual-plaza-base" d="M130 352h470" />
        <path class="visual-cerros" d="M0 290 C96 220 172 234 250 188 C332 140 420 168 502 120 C584 74 660 96 720 54" />
        {[148, 258, 370, 486, 584].map((x, index) => (
          <g class="visual-persona">
            <circle cx={x} cy={188 + (index % 2) * 48} r="24" />
            <path d={`M${x - 36} ${228 + (index % 2) * 48}c20-24 52-24 72 0`} />
          </g>
        ))}
        <path class="visual-conexion" d="M172 188 258 236 370 188 486 236 584 188" />
        <path class="visual-camino" d="M82 386 C172 326 262 334 352 286 C450 232 540 206 650 150" />
      </g>
    )}

    {variant === "sobre" && (
      <g class="visual-sobre">
        <path class="visual-geografia" d="M172 112c54-44 136-50 206-18 48 22 78 58 128 70 48 12 86-8 124 20 38 28 38 86 4 126-46 54-138 56-206 88-84 38-180 48-252-4-64-46-78-132-50-196 12-28 24-58 46-86Z" />
        <path class="visual-rio" d="M150 316 C226 276 264 226 348 218 C432 210 468 164 552 130" />
        <path class="visual-camino" d="M132 352 C218 310 264 260 342 246 C438 228 490 174 586 118" filter={`url(#resplandor-${variant})`} />
        <g class="visual-origen-marca">
          <circle cx="210" cy="320" r="24" />
          <path d="M210 296v-54m0 54c-26-14-42-36-52-68m52 68c28-16 44-40 58-72" />
        </g>
        <g class="visual-devpath">
          <rect x="430" y="96" width="146" height="78" rx="16" />
          <path d="M462 126h78M462 150h52" />
        </g>
      </g>
    )}
  </svg>
  )}
</div>
