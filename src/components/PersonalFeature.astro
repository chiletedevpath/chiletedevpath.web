<section class="seccion seccion-identidad">
  <div class="contenedor identidad-grid">
    <div class="identidad-media">
      <img
        src="/assets/img/adrian-pisco-retrato.webp"
        width="900"
        height="900"
        alt="Adrián Pisco, creador de Chilete DevPath"
        loading="lazy"
      />
      <div class="identidad-sello">
        <span>Chilete DevPath</span>
        <strong>Ruta técnica con identidad</strong>
      </div>
    </div>

    <div class="identidad-contenido">
      <p class="etiqueta">Detrás de la marca</p>
      <h2>Un camino técnico construido con evidencia real</h2>
      <p>
        Soy Adrián Pisco, estudiante de Ingeniería de Sistemas e Informática. Chilete DevPath
        reúne mi aprendizaje, proyectos, criterios y recursos para convertir el avance técnico
        en una ruta pública, útil y responsable.
      </p>
      <div class="identidad-puntos" aria-label="Pilares de Chilete DevPath">
        <span>Origen con identidad</span>
        <span>Práctica constante</span>
        <span>Criterio profesional</span>
      </div>
    </div>
  </div>
</section>
