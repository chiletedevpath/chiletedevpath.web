---
---

<section id="inicio" class="hero">
  <div class="contenedor hero-contenido">
    <div class="hero-texto">
      <p class="etiqueta">Chilete, Cajamarca, Perú | Desarrollo Full Stack</p>

      <h1>Chilete DevPath</h1>

      <p class="hero-descripcion">
        Soy Adrian Pisco, estudiante de Ingeniería de Sistemas e Informática. Construyo
        Chilete DevPath como una ruta pública donde mi aprendizaje, mis proyectos y mi
        criterio técnico se convierten en evidencia real para crecer con la comunidad.
      </p>

      <div class="acciones">
        <a class="boton boton-principal" href="/ruta/">Ver ruta de aprendizaje</a>
        <a class="boton boton-secundario" href="https://github.com/chiletedevpath" target="_blank" rel="noopener">
          Explorar GitHub
        </a>
      </div>

      <div class="hero-indicadores" aria-label="Resumen de la marca">
        <span>Origen con identidad</span>
        <span>Ruta técnica visible</span>
        <span>Comunidad en construcción</span>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-imagen">
        <img
          src="/assets/img/editorial/hero-inicio-candidato-v1.jpg"
          width="1792"
          height="1024"
          alt="Adrian Pisco trabajando en el ecosistema Chilete DevPath."
        />
        <div class="hero-marca-panel" aria-label="Enfoque de Chilete DevPath">
          <div>
            <span>Origen</span>
            <strong>Chilete</strong>
          </div>
          <div>
            <span>Ruta</span>
            <strong>Aprendizaje</strong>
          </div>
          <div>
            <span>Construye</span>
            <strong>Proyectos</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
