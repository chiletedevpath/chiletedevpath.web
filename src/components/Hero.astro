---
---

<section id="inicio" class="hero">
  <div class="contenedor hero-contenido">
    <div class="hero-texto">
      <p class="etiqueta">Desde Chilete, Cajamarca al desarrollo Full Stack</p>

      <h1>Aprende programación con ruta, práctica y evidencia real</h1>

      <p class="hero-descripcion">
        Chilete DevPath organiza mi camino de aprendizaje para que más estudiantes puedan empezar,
        practicar y publicar mejor sin perder criterio técnico.
      </p>

      <p class="hero-dinamico" aria-label="Mensajes principales de Chilete DevPath">
        <span>Aprende desde cero</span>
        <span>Practica con evidencia</span>
        <span>Construye proyectos reales</span>
        <span>Publica con criterio</span>
      </p>

      <div class="acciones">
        <a class="boton boton-principal" href="/ruta/">Ver ruta de aprendizaje</a>
        <a class="boton boton-secundario boton-externo" href="https://github.com/chiletedevpath" target="_blank" rel="noopener">
          Explorar GitHub
        </a>
      </div>

      <div class="hero-indicadores" aria-label="Resumen de la marca">
        <span>11 temas publicados</span>
        <span>3 proyectos con contexto</span>
        <span>4 criterios activos</span>
      </div>
    </div>

    <div class="hero-visual" aria-label="Panel visual de avance Chilete DevPath">
      <div class="hero-dashboard">
        <div class="dashboard-top">
          <span class="dashboard-status">Ruta activa</span>
          <strong>Chilete DevPath</strong>
        </div>

        <div class="dashboard-path" aria-label="Etapas de aprendizaje">
          {["Fundamentos", "Web", "Datos", "Backend", "Proyectos"].map((item, index) => (
            <div class="dashboard-step">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <strong>{item}</strong>
            </div>
          ))}
        </div>

        <div class="dashboard-terminal" aria-label="Resumen técnico">
          <span>devpath@chilete:~$</span>
          <p>aprender --orden --practica --criterio</p>
          <small>publicando avance verificable...</small>
        </div>

        <div class="dashboard-progress">
          <div>
            <span>Base técnica</span>
            <strong>70%</strong>
          </div>
          <div class="dashboard-barra">
            <span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
