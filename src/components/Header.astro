---
import { navItems } from "../data/site.js";

const { currentPath = "/" } = Astro.props;
const normalize = (path) => (path === "/index.html" ? "/" : path);
const activePath = normalize(currentPath);
---

<header class="encabezado">
  <nav class="navegacion contenedor" aria-label="Navegación principal">
    <a class="marca" href="/">
      <span class="marca-logo" aria-hidden="true">
        <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
      </span>
      <span>Chilete DevPath</span>
    </a>

    <button
      class="menu-boton"
      type="button"
      aria-expanded="false"
      aria-controls="menu-principal"
    >
      Menú
    </button>

    <ul id="menu-principal" class="menu">
      {
        navItems.map((item) => {
          const isActive = item.href === activePath;
          return (
            <li>
              <a class={isActive ? "enlace-activo" : ""} href={item.href} aria-current={isActive ? "page" : undefined}>
                {item.label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
