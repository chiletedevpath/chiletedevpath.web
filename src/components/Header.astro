---
import HeaderNav from "./HeaderNav.jsx";
import { navItems, navItemsEn, navMoreItems, navMoreItemsEn } from "../data/site.js";
import { languages } from "../i18n/languages.js";

const { currentPath = "/" } = Astro.props;
const normalize = (path) => (path === "/index.html" ? "/" : path);
const activePath = normalize(currentPath);
const isEnglish = activePath.startsWith("/en");
---

<header class="encabezado">
  <HeaderNav
    navItems={isEnglish ? navItemsEn : navItems}
    moreItems={isEnglish ? navMoreItemsEn : navMoreItems}
    languages={languages}
    currentPath={activePath}
    client:load
  />
</header>
