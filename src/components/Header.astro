---
import HeaderNav from "./HeaderNav.jsx";
import { navItems, socials } from "../data/site.js";

const { currentPath = "/" } = Astro.props;
const normalize = (path) => (path === "/index.html" ? "/" : path);
const activePath = normalize(currentPath);
const githubHref = socials.find((social) => social.name === "GitHub")?.href ?? "https://github.com/chiletedevpath";
---

<header class="encabezado">
  <HeaderNav navItems={navItems} currentPath={activePath} githubHref={githubHref} client:load />
</header>
