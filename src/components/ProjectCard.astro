---
const { project } = Astro.props;
---

<article class="tarjeta tarjeta-con-enlace">
  {project.imageSrc ? (
    <figure class="proyecto-visual proyecto-visual-imagen">
      <img src={project.imageSrc} alt={project.imageAlt ?? ""} loading="lazy" />
      {project.visual && <figcaption>{project.visual}</figcaption>}
    </figure>
  ) : project.visual && (
    <div class="proyecto-visual">
      <span>{project.visual}</span>
    </div>
  )}
  <span class="estado">{project.status}</span>
  {typeof project.progress === "number" && (
    <div class="avance-proyecto" aria-label={`Avance del proyecto ${project.progress}%`}>
      <div class="avance-proyecto-barra">
        <span style={`width: ${project.progress}%`}></span>
      </div>
      <strong>{project.progress}%</strong>
    </div>
  )}
  <h3>{project.title}</h3>
  <p>{project.description}</p>
  <ul class="tarjeta-detalles">
    {project.details.map((detail) => <li>{detail}</li>)}
  </ul>
  <a class="boton boton-principal" href={project.href} target="_blank" rel="noopener">
    {project.action}
  </a>
</article>
