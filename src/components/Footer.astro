---
import { navItems, navItemsEn, navMoreItems, navMoreItemsEn, site, socials } from "../data/site.js";
import { policies, policiesEn } from "../data/recursos.js";
import SocialIcon from "./SocialIcon.astro";

const { lang = "es" } = Astro.props;
const isEnglish = lang === "en";
const footerNav = isEnglish ? [...navItemsEn, ...navMoreItemsEn] : [...navItems, ...navMoreItems];
const footerPolicies = isEnglish
  ? policiesEn.map((policy) => ({ ...policy, href: `/en/politicas/${policy.slug}/` }))
  : policies;
---

<footer class="pie">
  <div class="pie-contenido">
    <div class="pie-marca">
      <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
      <div>
        <strong>{site.name}</strong>
        <p>
          {isEnglish
            ? "Built from Chilete, Cajamarca, Peru to share technical learning with judgment."
            : "Desarrollado desde Chilete, Cajamarca, Perú para compartir aprendizaje técnico con criterio."}
        </p>
      </div>
    </div>

    <nav class="pie-columna" aria-label={isEnglish ? "Quick links" : "Enlaces rápidos"}>
      <strong>{isEnglish ? "Navigation" : "Navegación"}</strong>
      {footerNav.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <nav class="pie-columna" aria-label={isEnglish ? "Chilete DevPath policies" : "Políticas de Chilete DevPath"}>
      <strong>{isEnglish ? "Policies" : "Políticas"}</strong>
      {footerPolicies.map((policy) => <a href={policy.href}>{policy.title}</a>)}
    </nav>

    <div class="pie-social">
      <p>
        {isEnglish
          ? "Join Discord or review the public progress on GitHub."
          : "Únete a Discord o revisa el avance público en GitHub."}
      </p>
      <nav class="pie-redes" aria-label={isEnglish ? "Official social links" : "Redes oficiales"}>
        {socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener" aria-label={social.name}>
            <SocialIcon name={social.name} />
          </a>
        ))}
      </nav>
      <span class="version-marca">{site.version}</span>
    </div>
  </div>
  <div class="pie-inferior">
    <span>{isEnglish ? "Chilete DevPath by Adrián Pisco." : "Chilete DevPath por Adrián Pisco."}</span>
    <span>&copy; 2026</span>
  </div>
</footer>
