---
import { site, socials } from "../data/site.js";
import SocialIcon from "./SocialIcon.astro";
---

<footer class="pie">
  <div class="pie-contenido">
    <div class="pie-marca">
      <img src="/assets/img/marca-simbolo-nav.png" width="512" height="512" alt="" />
      <div>
        <strong>{site.name}</strong>
        <p>
          <span id="anio"></span>
          Aprendizaje real, criterio técnico y evolución profesional.
        </p>
      </div>
    </div>

    <div class="pie-cta">
      <p>Comparte avances, preguntas y práctica con la comunidad.</p>
      <a class="boton boton-principal" href="https://discord.gg/4XsXRT4rG" target="_blank" rel="noopener">
        Unirme a Discord
      </a>
    </div>

    <div class="pie-social">
      <nav class="pie-redes" aria-label="Redes oficiales">
        {socials.map((social) => (
          <a href={social.href} target="_blank" rel="noopener" aria-label={social.name}>
            <SocialIcon name={social.name} />
          </a>
        ))}
      </nav>

      <span class="version-marca">{site.version}</span>
    </div>
  </div>
</footer>
