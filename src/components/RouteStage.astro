---
const { stage } = Astro.props;
---

<article class="ruta-etapa">
  <span class="ruta-numero">{stage.number}</span>
  <span class="ruta-meta">{stage.intent}</span>
  <h3>{stage.title}</h3>
  {Array.isArray(stage.technologies) && (
    <div class="ruta-tecnologias" aria-label="Tecnologías y conceptos de la etapa">
      {stage.technologies.map((tech) => <span>{tech}</span>)}
    </div>
  )}
  <ol class="ruta-lista">
    {stage.topics.map((topic) => (
      <li>
        <a href={topic.href} target="_blank" rel="noopener noreferrer">{topic.label}</a>
      </li>
    ))}
  </ol>
  {typeof stage.progress === "number" && (
    <div class="ruta-avance" aria-label={`Avance de etapa ${stage.progress}%`}>
      <div>
        <span>Avance de etapa</span>
        <strong>{stage.progress}%</strong>
      </div>
      <div class="ruta-avance-barra">
        <span style={`width: ${stage.progress}%`}></span>
      </div>
    </div>
  )}
  <p class="ruta-resultado">Resultado: {stage.result}</p>
  <div class="ruta-pie">
    <span class="estado estado-etapa">{stage.status}</span>
    <a href={stage.href} target="_blank" rel="noopener noreferrer">{stage.action}</a>
  </div>
</article>
