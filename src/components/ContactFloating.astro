---
import { site } from "../data/site.js";

const message = encodeURIComponent(
  "Hola, vengo desde la web de Chilete DevPath. Quisiera hacer una consulta sobre la ruta de aprendizaje."
);
const whatsappHref = site.whatsapp ? `https://wa.me/${site.whatsapp}?text=${message}` : `https://wa.me/?text=${message}`;
---

<a class="whatsapp-flotante" href={whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="Contactar por WhatsApp">
  <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
    <path d="M12 3a8.7 8.7 0 0 0-7.4 13.3L3.8 21l4.8-1.3A8.7 8.7 0 1 0 12 3Zm4.9 12.4c-.2.6-1.2 1.1-1.7 1.2-.5.1-1.1.2-3.6-.8-3-1.2-4.9-4.3-5-4.5-.1-.2-1.2-1.6-1.2-3 0-1.4.7-2.1 1-2.4.2-.3.6-.4.8-.4h.6c.2 0 .5 0 .7.5.3.6.9 2.1 1 2.3.1.2.1.4 0 .6-.1.2-.2.4-.4.6l-.3.4c-.1.1-.3.3-.1.6.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.3 2.4 1.5.3.1.5.1.7-.1l.9-1.1c.2-.3.5-.2.8-.1.3.1 2 .9 2.3 1.1.3.2.5.3.6.4.1.1.1.5-.1 1.1Z" />
  </svg>
  <span>WhatsApp</span>
</a>
