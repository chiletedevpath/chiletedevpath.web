---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ContactFloating from "../components/ContactFloating.astro";
import { site } from "../data/site.js";

const {
  title = `${site.name} | ${site.author}`,
  description = site.description,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, site.url).href;
const socialImage = `${site.url}/assets/img/og-image.jpg`;
const lang = Astro.url.pathname.startsWith("/en") ? "en" : "es";
const pathname = Astro.url.pathname;
const spanishPath = pathname.startsWith("/en") ? pathname.replace(/^\/en/, "") || "/" : pathname;
const englishPath = pathname.startsWith("/en") ? pathname : `/en${pathname === "/" ? "/" : pathname}`;
const spanishUrl = new URL(spanishPath, site.url).href;
const englishUrl = new URL(englishPath, site.url).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <meta name="robots" content="index, follow" />
    <meta name="application-name" content={site.name} />
    <meta name="apple-mobile-web-app-title" content={site.name} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Chilete DevPath, marca personal de Adrián Pisco para aprendizaje y proyectos Full Stack." />
    <meta property="og:locale" content="es_PE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Chilete DevPath, marca personal de Adrián Pisco para aprendizaje y proyectos Full Stack." />
    <meta name="theme-color" content="#f5f7f5" />
    <meta name="cdp-email" content={site.email} />
    <script is:inline>
      (() => {
        const temaGuardado = localStorage.getItem("cdp-theme");
        const temaSistema = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        document.documentElement.dataset.theme = temaGuardado || temaSistema;
      })();
    </script>
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={spanishUrl} />
    <link rel="alternate" hreflang="en" href={englishUrl} />
    <link rel="alternate" hreflang="x-default" href={spanishUrl} />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" href="/assets/img/marca-simbolo-nav.png" />
    <link rel="apple-touch-icon" href="/assets/img/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,700;9..144,800&family=Geist+Mono:wght@600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <a class="salto-contenido" href="#contenido">Saltar al contenido principal</a>
    <Header currentPath={Astro.url.pathname} />
    <main id="contenido">
      <slot />
    </main>
    <ContactFloating />
    <Footer lang={lang} />
    <script src="../scripts/main.js"></script>
  </body>
</html>
